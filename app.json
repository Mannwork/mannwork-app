{
    "expo": {
        "name": "Mannwork",
        "slug": "mannwork",
        "version": "1.0.1",
        "orientation": "portrait",
        "icon": "./assets/images/icon.png",
        "scheme": "mannwork",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.dillmanncode.mannwork",
            "config": {},
            "infoPlist": {
                "ITSAppUsesNonExemptEncryption": false,
                "NSLocationWhenInUseUsageDescription": "Necesitamos tu ubicación para mostrarte en el mapa.",
                "NSCameraUsageDescription": "Necesitamos acceso a la cámara para que puedas tomar fotos y enviarlas en el chat.",
                "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tu galería para que puedas compartir imágenes en el chat.",
                "NSPhotoLibraryAddUsageDescription": "Necesitamos guardar fotos en tu galería.",
                "NSDocumentsFolderUsageDescription": "Necesitamos acceso a tus archivos para que puedas compartir documentos en el chat."
            }
        },
        "android": {
            "permissions": [
                "ACCESS_COARSE_LOCATION",
                "ACCESS_FINE_LOCATION",
                "FOREGROUND_SERVICE",
                "ACCESS_COARSE_LOCATION",
                "ACCESS_FINE_LOCATION",
                "FOREGROUND_SERVICE"
            ],
            "adaptiveIcon": {
                "foregroundImage": "./assets/images/adaptive-icon.png",
                "backgroundColor": "#2D7A3E"
            },
            "edgeToEdgeEnabled": true,
            "package": "com.dillmanncode.mannwork",
            "config": {
                "googleMaps": {
                    "apiKey": "AIzaSyCSq-wIJqaMFT2ZBV_Oz8IplUrE29mtfXU"
                }
            },
            "googleServicesFile": "./google-services.json"
        },
        "web": {
            "bundler": "metro",
            "output": "static",
            "favicon": "./assets/images/favicon.png"
        },
        "plugins": [
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "image": "./assets/images/adaptive-icon.png",
                    "imageWidth": 200,
                    "resizeMode": "contain",
                    "backgroundColor": "#2D7A3E"
                }
            ],
            "expo-web-browser",
            [
                "expo-document-picker",
                {
                    "iCloudContainerEnvironment": "Production"
                }
            ],
            "expo-font",
            "expo-notifications",
            [
                "@sentry/react-native/expo",
                {
                    "url": "https://sentry.io/",
                    "project": "react-native",
                    "organization": "mannwork"
                }
            ],
            "expo-secure-store"
        ],
        "notification": {
            "icon": "./assets/images/push-notification-icon.png",
            "color": "#ffffff"
        },
        "experiments": {
            "typedRoutes": true
        },
        "extra": {
            "router": {},
            "eas": {
                "projectId": "ba42f55f-f743-402f-bc73-13aea55d70bc"
            }
        },
        "runtimeVersion": {
            "policy": "appVersion"
        },
        "updates": {
            "enabled": false
        }
    }
}
